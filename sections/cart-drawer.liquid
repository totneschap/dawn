    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Checkout button label",
      "default": "Check out"
    },
    {
      "type": "checkbox",
      "id": "show_view_cart_link",
      "label": "Show 'View full cart' link",
