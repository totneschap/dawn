{{ 'section-image-text-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  case section.settings.image_position
    when 'top'
      assign img_pos = 'top'
    when 'bottom'
      assign img_pos = 'bottom'
    else
      assign img_pos = 'center'
  endcase
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #ITS-{{ section.id }} {
    --its-desktop-height: {{ section.settings.desktop_height }}px;
    --its-mobile-height:  {{ section.settings.mobile_height }}px;
    --its-image-position: {{ img_pos }};
  }
{%- endstyle -%}

<div class="its-outer its-outer--{{ section.settings.section_width }} section-{{ section.id }}-padding">
  {%- if section.settings.section_width == 'page-width' -%}
    <div class="page-width">
  {%- endif -%}

  <div id="ITS-{{ section.id }}">
    <div class="its__inner its__inner--text-{{ section.settings.text_position }}">

      <!-- Fixed image -->
      <div class="its__image-col">
        {%- if section.settings.image != blank -%}
          {%- assign img_alt = section.settings.image.alt | escape -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag:
            loading: 'lazy',
            widths: '600, 800, 1000, 1200, 1400',
            alt: img_alt
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      <!-- Text slider column -->
      <div class="its__content-col color-{{ section.settings.color_scheme }} gradient">

        <div class="its__text-track-outer">
          <div class="its__text-track">
            {%- for block in section.blocks -%}
              <div class="its__text-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                {%- if block.settings.subheading != blank -%}
                  <span class="its__subheading">{{ block.settings.subheading }}</span>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="its__heading inline-richtext {{ section.settings.heading_size }}">
                    {{- block.settings.heading -}}
                  </h2>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="its__text rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link | default: '#' }}"
                    class="its__button button button--primary"
                  >
                    {{- block.settings.button_label -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if section.blocks.size > 1 -%}
          <div class="its__controls">
            <button class="its__nav-btn its__prev" aria-label="Previous slide">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M12.5 5L7.5 10L12.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="its__dots">
              {%- for block in section.blocks -%}
                <button
                  class="its__dot{% if forloop.first %} is-active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="Slide {{ forloop.index }}"
                ></button>
              {%- endfor -%}
            </div>

            <button class="its__nav-btn its__next" aria-label="Next slide">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endif -%}

      </div><!-- /.its__content-col -->

    </div><!-- /.its__inner -->
  </div><!-- /#ITS -->

  {%- if section.settings.section_width == 'page-width' -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function () {
    var its      = document.getElementById('ITS-{{ section.id }}');
    if (!its) return;

    var track    = its.querySelector('.its__text-track');
    var slides   = Array.from(its.querySelectorAll('.its__text-slide'));
    var dots     = Array.from(its.querySelectorAll('.its__dot'));
    var prevBtn  = its.querySelector('.its__prev');
    var nextBtn  = its.querySelector('.its__next');
    var total    = slides.length;
    var current  = 0;
    var autoplay = {{ section.settings.autoplay }};
    var speed    = {{ section.settings.autoplay_speed | times: 1000 }};
    var timer    = null;

    function goTo(index) {
      current = ((index % total) + total) % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      slides.forEach(function (s, i) { s.classList.toggle('is-active', i === current); });
      dots.forEach(function (d, i)   { d.classList.toggle('is-active', i === current); });
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); resetAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); resetAutoplay(); });
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.index, 10)); resetAutoplay(); });
    });

    function startAutoplay() {
      if (!autoplay || total <= 1) return;
      timer = setInterval(function () { goTo(current + 1); }, speed);
    }

    function resetAutoplay() {
      clearInterval(timer);
      startAutoplay();
    }

    its.addEventListener('mouseenter', function () { clearInterval(timer); });
    its.addEventListener('mouseleave', function () { startAutoplay(); });

    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Image with text slider",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full",       "label": "Full width" },
        { "value": "padded",     "label": "Full width with padding" },
        { "value": "page-width", "label": "Page width" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text side",
      "options": [
        { "value": "right", "label": "Right (image left)" },
        { "value": "left",  "label": "Left (image right)" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Height"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile image height",
      "min": 200,
      "max": 600,
      "step": 25,
      "unit": "px",
      "default": 350,
      "info": "Height of the image on mobile. Text content appears below and expands to fit."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-advance slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Time between slides",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Text panel color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Bold statement goes here"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair your image with a short description to give customers insight into your brand.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subheading": "Spring / Summer 2025",
            "heading": "New arrivals are here",
            "text": "<p>Discover our latest collection, crafted with care and designed to last.</p>",
            "button_label": "Shop now"
          }
        },
        {
          "type": "slide",
          "settings": {
            "subheading": "Our story",
            "heading": "Made for the way you live",
            "text": "<p>Sustainably sourced, beautifully made — pieces you'll reach for again and again.</p>",
            "button_label": "Learn more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
