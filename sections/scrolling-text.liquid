{{ 'section-scrolling-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {%- if section.settings.font_size_custom > 0 -%}
    #StTrack-{{ section.id }} { font-size: {{ section.settings.font_size_custom }}px; }
  {%- endif -%}
{%- endstyle -%}

{%- assign duration = section.settings.speed | times: -8 | plus: 88 -%}

{%- unless section.blocks.size == 0 -%}
  <div class="scrolling-text color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <div class="page-width">
        <h2 class="scrolling-text__heading {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}
    <div class="scrolling-text__viewport">
      <ul
        class="scrolling-text__track scrolling-text__track--{{ section.settings.direction }} scrolling-text__track--{{ section.settings.font_size }} list-unstyled"
        style="--st-duration: {{ duration }}s;"
        role="list"
        id="StTrack-{{ section.id }}"
      >
        {%- for block in section.blocks -%}
          <li class="scrolling-text__item" {{ block.shopify_attributes }}>
            <span class="scrolling-text__text">{{ block.settings.text }}</span>
            {%- if section.settings.separator != blank -%}
              <span class="scrolling-text__separator" aria-hidden="true">{{ section.settings.separator }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <script>
      (function () {
        function init(track) {
          var items = Array.from(track.children);
          if (!items.length) return;

          var singleWidth = items.reduce(function (sum, el) {
            return sum + el.getBoundingClientRect().width;
          }, 0);

          if (singleWidth === 0) return;

          var needed = Math.max(window.innerWidth * 3, singleWidth * 4);
          var total = singleWidth;
          while (total < needed) {
            items.forEach(function (item) {
              var clone = item.cloneNode(true);
              clone.setAttribute('aria-hidden', 'true');
              track.appendChild(clone);
            });
            total += singleWidth;
          }

          track.style.setProperty('--st-scroll-distance', singleWidth + 'px');
        }

        var track = document.getElementById('StTrack-{{ section.id }}');
        if (!track) return;
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(function () { init(track); });
        } else {
          init(track);
        }
      })();
    </script>
  </div>
{%- endunless -%}

{% schema %}
{
  "name": "Scrolling text",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "info": "Optional heading shown above the scrolling text. Leave blank to hide."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Scrolling text"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5,
      "info": "1 = slowest, 10 = fastest"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Text size preset",
      "options": [
        { "value": "small",  "label": "Small (~13px)" },
        { "value": "medium", "label": "Medium (~20px)" },
        { "value": "large",  "label": "Large (~36px)" },
        { "value": "xlarge", "label": "Extra large (~60px)" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "font_size_custom",
      "label": "Custom text size",
      "info": "Overrides the preset above. Set to 0 to use the preset.",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "✦",
      "info": "Character shown between items. Leave blank to remove."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text item",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over £50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling text",
      "blocks": [
        { "type": "text_item" },
        { "type": "text_item", "settings": { "text": "New arrivals every week" } },
        { "type": "text_item", "settings": { "text": "Sustainably made" } }
      ]
    }
  ]
}
{% endschema %}
