{{ 'section-text-columns-images.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign col_count             = section.settings.columns_desktop
  assign col_count_mobile      = section.settings.columns_mobile | plus: 0
  assign gap_count             = col_count | minus: 1
  assign gap_count_mobile      = col_count_mobile | minus: 1
  assign show_mobile_slider    = false
  if section.settings.swipe_on_mobile and section.blocks.size > col_count_mobile
    assign show_mobile_slider = true
  endif
-%}

<div class="text-columns-images color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="text-columns-images__header{% if section.settings.column_alignment == 'center' %} center{% endif %}">
        {%- if section.settings.title != blank -%}
          <h2 class="text-columns-images__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="text-columns-images__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- unless section.blocks.size == 0 -%}
      {%- capture img_sizes -%}
        (min-width: 990px) calc((100vw - 10rem) / {{ col_count }}), (min-width: 750px) calc((100vw - 8rem) / {{ col_count_mobile }}), calc(100vw - 3rem)
      {%- endcapture -%}
      <slider-component>
        <ul
          class="text-columns-images__list text-columns-images__list--align-{{ section.settings.row_alignment }}{% if show_mobile_slider %} slider slider--mobile{% endif %} list-unstyled"
          id="Slider-{{ section.id }}"
          style="--tcwi-cols: {{ col_count }}; --tcwi-gap-count: {{ gap_count }}; --tcwi-cols-mobile: {{ col_count_mobile }}; --tcwi-gap-count-mobile: {{ gap_count_mobile }};"
          role="list"
        >
          {%- for block in section.blocks -%}
            <li
              class="text-columns-images__item{% if show_mobile_slider %} slider__slide{% endif %}{% if section.settings.card_style %} text-columns-images__item--card content-container{% endif %}{% if section.settings.column_alignment == 'center' %} center{% endif %}"
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              {{ block.shopify_attributes }}
            >
            {%- if block.settings.image != blank -%}
              <div class="text-columns-images__img-wrapper text-columns-images__img-wrapper--{{ section.settings.image_ratio }}">
                {{ block.settings.image | image_url: width: 1500 | image_tag:
                  loading: 'lazy',
                  widths: '375, 550, 750, 900, 1200, 1500',
                  sizes: img_sizes,
                  class: 'text-columns-images__img'
                }}
              </div>
            {%- endif -%}

            <div class="text-columns-images__body">
              {%- if block.settings.title != blank -%}
                <h3 class="text-columns-images__item-heading inline-richtext">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="text-columns-images__item-text rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {%- if block.settings.link_label != blank -%}
                <a
                  class="{% if block.settings.link_style == 'button' %}button button--secondary{% else %}link animate-arrow{% endif %}"
                  {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                >
                  {{- block.settings.link_label | escape -}}
                  {%- if block.settings.link_style == 'link' -%}
                    <span class="svg-wrapper"><span class="icon-wrap">&nbsp;{{ 'icon-arrow.svg' | inline_asset_content }}</span></span>
                  {%- endif -%}
                </a>
              {%- endif -%}
            </div>
          </li>
          {%- endfor -%}
        </ul>

        {%- if show_mobile_slider -%}
          <div class="slider-buttons text-columns-images__slider-buttons">
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </button>
            <div class="slider-counter caption">
              <span class="slider-counter--current">1</span>
              <span aria-hidden="true"> / </span>
              <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
              <span class="slider-counter--total">{{ section.blocks.size }}</span>
            </div>
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
            >
              <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
            </button>
          </div>
        {%- endif -%}
      </slider-component>
    {%- endunless -%}
  </div>
</div>

{% schema %}
{
  "name": "Text columns with images",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Our features"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Optional subheading shown below the section title."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural (adapts to image)" },
        { "value": "square",  "label": "Square (1:1)" },
        { "value": "portrait","label": "Portrait (2:3)" },
        { "value": "landscape","label": "Landscape (3:2)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Items per row (desktop)",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Items per row (mobile)",
      "options": [
        { "value": "1", "label": "1 per row" },
        { "value": "2", "label": "2 per row" }
      ],
      "default": "1"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "label": "Enable swipe on mobile",
      "default": false,
      "info": "Shows a scrollable slider on mobile when there are more items than fit in a row."
    },
    {
      "type": "select",
      "id": "row_alignment",
      "label": "Row alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Centre" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left",
      "info": "Controls how items sit in a row — most noticeable when the last row has fewer items than the per-row count."
    },
    {
      "type": "select",
      "id": "column_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "card_style",
      "label": "Show columns as cards",
      "default": false,
      "info": "Wraps each column in a card using your theme card style settings."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "link_style",
          "label": "Button style",
          "options": [
            { "value": "link",   "label": "Link with arrow" },
            { "value": "button", "label": "Solid button" }
          ],
          "default": "link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text columns with images",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
