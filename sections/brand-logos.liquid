{{ 'section-brand-logos.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign duration = section.settings.speed | times: -10 | plus: 110
  assign logo_height_2x = section.settings.logo_height | times: 2
  assign has_logos = false
  for block in section.blocks
    if block.settings.image != blank
      assign has_logos = true
      break
    endif
  endfor
-%}

{%- if has_logos -%}
  <div class="brand-logos color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">

    {%- if section.settings.title != blank -%}
      <div class="page-width">
        <h2 class="brand-logos__heading {{ section.settings.heading_size }}">{{ section.settings.title | escape }}</h2>
      </div>
    {%- endif -%}

    <div
      class="brand-logos__viewport"
      style="--bl-logo-height: {{ section.settings.logo_height }}px; --bl-duration: {{ duration }}s;"
    >
      <ul
        class="brand-logos__track brand-logos__track--{{ section.settings.direction }}{% if section.settings.grayscale %} brand-logos__track--grayscale{% endif %} list-unstyled"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            {%- assign logo_alt = block.settings.image.alt | escape -%}
            <li class="brand-logos__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="brand-logos__link" aria-label="{{ logo_alt }}">
              {%- endif -%}
              {{ block.settings.image | image_url: height: logo_height_2x | image_tag:
                loading: 'lazy',
                class: 'brand-logos__img',
                alt: logo_alt
              }}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Duplicate set for seamless loop {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            <li class="brand-logos__item" aria-hidden="true">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="brand-logos__link" tabindex="-1">
              {%- endif -%}
              {{ block.settings.image | image_url: height: logo_height_2x | image_tag:
                loading: 'lazy',
                class: 'brand-logos__img',
                alt: ''
              }}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

  </div>
{%- endif -%}

{% schema %}
{
  "name": "Brand logos",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Trusted by"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Logos"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Show logos in greyscale",
      "default": true,
      "info": "Logos fade to full colour on hover."
    },
    {
      "type": "header",
      "content": "Scroll"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4,
      "info": "1 = slowest, 10 = fastest"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional — links the logo to a brand or collection page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
