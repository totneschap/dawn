{{ 'component-countdown-timer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'countdown-timer.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.settings.end_date != blank -%}
  <div class="countdown-timer-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" id="CountdownTimer-{{ section.id }}">
    <div class="page-width">
      <countdown-timer
        class="countdown-timer"
        data-end-date="{{ section.settings.end_date | escape }}"
        data-expired-text="{{ section.settings.expired_text | escape }}"
        data-section-id="{{ section.id }}"
        data-show-seconds="{{ section.settings.show_seconds }}"
      >
        {%- if section.settings.heading != blank -%}
          <p class="countdown-timer__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</p>
        {%- endif -%}

        <div class="countdown-timer__timer" aria-live="off">
          <div class="countdown-timer__unit">
            <span class="countdown-timer__value" data-days aria-label="days">00</span>
            <span class="countdown-timer__label" aria-hidden="true">Days</span>
          </div>
          <span class="countdown-timer__sep" aria-hidden="true">:</span>
          <div class="countdown-timer__unit">
            <span class="countdown-timer__value" data-hours aria-label="hours">00</span>
            <span class="countdown-timer__label" aria-hidden="true">Hours</span>
          </div>
          <span class="countdown-timer__sep" aria-hidden="true">:</span>
          <div class="countdown-timer__unit">
            <span class="countdown-timer__value" data-minutes aria-label="minutes">00</span>
            <span class="countdown-timer__label" aria-hidden="true">Mins</span>
          </div>
          {%- if section.settings.show_seconds -%}
            <span class="countdown-timer__sep" aria-hidden="true">:</span>
            <div class="countdown-timer__unit">
              <span class="countdown-timer__value" data-seconds aria-label="seconds">00</span>
              <span class="countdown-timer__label" aria-hidden="true">Secs</span>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.expired_text != blank -%}
          <p class="countdown-timer__expired" hidden>{{ section.settings.expired_text | escape }}</p>
        {%- endif -%}

      </countdown-timer>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Countdown timer",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sale ends in"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" }
      ],
      "default": "h3"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date and time",
      "info": "Format: YYYY-MM-DD HH:MM:SS — e.g. 2025-12-31 23:59:59. Time is in the visitor's local timezone."
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Show seconds",
      "default": true
    },
    {
      "type": "text",
      "id": "expired_text",
      "label": "Expired message",
      "info": "Shown when the timer reaches zero. Leave blank to hide the section automatically."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Countdown timer"
    }
  ]
}
{% endschema %}
