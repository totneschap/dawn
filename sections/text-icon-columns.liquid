{{ 'section-text-icon-columns.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign col_count        = section.settings.columns_desktop
  assign col_count_mobile = section.settings.columns_mobile | plus: 0
  assign gap_count        = col_count | minus: 1
  assign gap_count_mobile = col_count_mobile | minus: 1
  assign icon_px_2x       = section.settings.icon_size | times: 2
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #TextIconCols-{{ section.id }} {
    --tic-icon-size: {{ section.settings.icon_size }}px;
  }
{%- endstyle -%}

<div
  class="text-icon-cols color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  id="TextIconCols-{{ section.id }}"
>
  <div class="page-width">

    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="text-icon-cols__header {{ section.settings.header_alignment }}">
        {%- if section.settings.title != blank -%}
          <h2 class="text-icon-cols__heading inline-richtext {{ section.settings.heading_size }}">
            {{- section.settings.title -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="text-icon-cols__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="text-icon-cols__list list-unstyled"
        style="--tic-cols: {{ col_count }}; --tic-gap-count: {{ gap_count }}; --tic-cols-mobile: {{ col_count_mobile }}; --tic-gap-count-mobile: {{ gap_count_mobile }};"
        role="list"
      >
        {%- for block in section.blocks -%}
          <li
            class="text-icon-cols__item {{ section.settings.column_alignment }}"
            {{ block.shopify_attributes }}
          >

            {%- if block.settings.icon != blank -%}
              {%- assign icon_alt = block.settings.icon.alt | escape -%}
              <div class="text-icon-cols__icon-wrapper text-icon-cols__icon-wrapper--{{ section.settings.icon_style }}">
                {{ block.settings.icon | image_url: width: icon_px_2x | image_tag:
                  loading: 'lazy',
                  class: 'text-icon-cols__icon',
                  alt: icon_alt
                }}
              </div>
            {%- elsif block.settings.emoji != blank -%}
              <div class="text-icon-cols__icon-wrapper text-icon-cols__icon-wrapper--{{ section.settings.icon_style }}">
                <span class="text-icon-cols__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
              </div>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              <h3 class="text-icon-cols__item-heading {{ section.settings.item_heading_size }}">
                {{- block.settings.heading -}}
              </h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="text-icon-cols__item-text rte">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.link_label != blank and block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="text-icon-cols__item-link link link--text">
                {{ block.settings.link_label }}
              </a>
            {%- endif -%}

          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Text columns with icons",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Columns"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "label": "Column alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "item_heading_size",
      "label": "Item heading size",
      "options": [
        { "value": "h5", "label": "Small" },
        { "value": "h4", "label": "Medium" },
        { "value": "h3", "label": "Large" }
      ],
      "default": "h4"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon background",
      "options": [
        { "value": "plain",  "label": "None" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Rounded square" }
      ],
      "default": "plain"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Upload a PNG, SVG, or WebP icon. Recommended size: 96×96px."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon emoji",
          "info": "Used when no image is uploaded. Paste any emoji or symbol, e.g. ✦ 🚚 ♻️ ✓"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Column heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Pair text with an icon to explain your brand values and what makes you different.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Text columns with icons",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "emoji": "🚚",
            "heading": "Free delivery",
            "text": "<p>On all orders over £50 within the UK.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "emoji": "♻️",
            "heading": "Sustainably made",
            "text": "<p>Using materials that are kind to the planet.</p>"
          }
        },
        {
          "type": "column",
          "settings": {
            "emoji": "✦",
            "heading": "Premium quality",
            "text": "<p>Crafted to the highest standards, built to last.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
