{{ 'section-shop-the-look.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #ShopTheLook-{{ section.id }} {
    --stl-image-width: {{ section.settings.image_width }};
  }
{%- endstyle -%}

<div
  class="shop-the-look color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding{% if section.settings.uppercase_heading %} section--uppercase-heading{% endif %}"
  id="ShopTheLook-{{ section.id }}"
>
  <div class="page-width">

    <div class="shop-the-look__grid shop-the-look__grid--image-{{ section.settings.image_position }}">

      <!-- Image column -->
      <div class="shop-the-look__image-col">
        {%- if section.settings.image != blank -%}
          {%- assign main_alt = section.settings.image.alt | escape -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1200, 1400',
            class: 'shop-the-look__img',
            alt: main_alt
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'shop-the-look__img shop-the-look__img--placeholder' }}
        {%- endif -%}
      </div>

      <!-- Products column -->
      <div class="shop-the-look__content-col">
        {%- if section.settings.title != blank -%}
          <h2
            class="shop-the-look__heading inline-richtext {{ section.settings.heading_size }}"
            style="text-align: {{ section.settings.heading_alignment }};"
          >{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div
            class="shop-the-look__description rte"
            style="text-align: {{ section.settings.text_alignment }};"
          >{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="shop-the-look__btn button button--primary"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="shop-the-look__products list-unstyled" role="list">
            {%- for block in section.blocks -%}
              {%- assign stl_product = all_products[block.settings.product] -%}
              {%- if stl_product != empty -%}
                {%- assign stl_alt = stl_product.featured_image.alt | escape -%}
                <li class="shop-the-look__product" {{ block.shopify_attributes }}>

                  <a href="{{ stl_product.url }}" class="shop-the-look__product-image-link" tabindex="-1" aria-hidden="true">
                    {%- if stl_product.featured_image != blank -%}
                      {{ stl_product.featured_image | image_url: width: 200 | image_tag:
                        loading: 'lazy',
                        widths: '80, 120, 160, 200',
                        class: 'shop-the-look__product-img',
                        alt: stl_alt
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'shop-the-look__product-img' }}
                    {%- endif -%}
                  </a>

                  <div class="shop-the-look__product-details">
                    <p class="shop-the-look__product-title">
                      <a href="{{ stl_product.url }}">{{ stl_product.title }}</a>
                    </p>
                    <p class="shop-the-look__product-price">
                      {%- if stl_product.compare_at_price > stl_product.price -%}
                        <span class="shop-the-look__price--sale">{{ stl_product.price | money }}</span>
                        <s class="shop-the-look__price--compare">{{ stl_product.compare_at_price | money }}</s>
                      {%- else -%}
                        <span>{{ stl_product.price | money }}</span>
                      {%- endif -%}
                    </p>
                    <a href="{{ stl_product.url }}" class="shop-the-look__product-button button button--secondary">
                      {{ block.settings.button_label | default: 'Shop now' }}
                    </a>
                  </div>

                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p style="opacity:0.4;">Add product blocks to showcase items.</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop the look",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Shop the look"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Text",
      "info": "Optional text shown below the heading."
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave blank to hide the button."
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "Image width",
      "options": [
        { "value": "40%", "label": "40%" },
        { "value": "50%", "label": "50%" },
        { "value": "60%", "label": "60%" }
      ],
      "default": "50%",
      "info": "Percentage of section width. Products fill the remaining space."
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Uppercase heading",
      "default": false
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 8,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the look",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
